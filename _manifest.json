{
  "manifest_version": 2,
  "version": "1.0.0",
  "name": "麦可当劳(MaicLaude):Maibot Using Claude Code CLI",
  "description": "通过 QQ 命令在 MaiBot 所在服务器上运行 Claude Code CLI。支持本机任务执行、实时进度转发、NapCat 文件直传与输入。基于 Arcczr/maibot-codex-plugin (MIT) 改造。",
  "author": {
    "name": "QR-0W",
    "url": "https://github.com/QR-0W"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/QR-0W/maibot-maiclaude-plugin",
    "homepage": "https://github.com/QR-0W/maibot-maiclaude-plugin",
    "documentation": "https://github.com/QR-0W/maibot-maiclaude-plugin#readme",
    "issues": "https://github.com/QR-0W/maibot-maiclaude-plugin/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.5.2",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "httpx",
      "version_spec": ">=0.28.0"
    }
  ],
  "plugin_type": "integration",
  "display": {
    "icon": {
      "type": "local",
      "value": "icon.svg",
      "fallback": "terminal"
    }
  },
  "capabilities": [
    "api.call",
    "send.text",
    "send.custom",
    "message.get_by_id"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": "i18n",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "id": "qr0w.maiclaude"
}
